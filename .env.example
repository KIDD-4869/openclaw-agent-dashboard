# OpenClaw Agent Dashboard 环境变量

# OpenClaw 数据目录（容器内路径，只读挂载）
OPENCLAW_DIR=/home/node/.openclaw

# Dashboard 监听端口
PORT=3001

# Dashboard 数据存储目录（议政记录、任务索引等）
DASHBOARD_DATA_DIR=/app/data

# OpenClaw Gateway 连接（用于任务控制：取消/暂停/恢复）
GATEWAY_HOST=openclaw
GATEWAY_PORT=18789

# LLM API（朝堂议政功能需要，不用议政可不填）
# BASE_URL=http://your-llm-api/v1
# API_KEY=your-api-key

# 时区
TZ=Asia/Shanghai
